# Globa Pay — environment template
# Copy to Railway Variables (or local .env). Never commit real secrets.

# ── Required in production ──────────────────────────────────────────
NODE_ENV=production
PUBLIC_BASE_URL=https://globa-cash.us
DATABASE_URL=postgresql://user:password@host:5432/railway

# Strong admin login (min 12 chars, letter + number, not a placeholder)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=replace-with-a-long-unique-password-9

# Cash App / Lightning (recommended cloud setup)
# getalby.com → Lightning Address + Developer access token
ALBY_LIGHTNING_ADDRESS=yourname@getalby.com
ALBY_API_TOKEN=your_access_token_here

# Optional fallback if cloud token unavailable (laptop must stay online)
# NWC_URL=nostr+walletconnect://...

# ── Optional ────────────────────────────────────────────────────────
PORT=3000
CONTACT_EMAIL=payments@yourcompany.com
SYNC_INTERVAL_MS=30000
# SESSION_TTL_MS=604800000
# JSON_BODY_LIMIT=64kb

# Local-only JSON storage folder when DATABASE_URL is unset
# DATA_DIR=./data
