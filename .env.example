# Recommended for production (24/7 — no laptop / Alby Hub required):
# getalby.com → Developer → New Access Token → invoices:create + invoices:read
# ALBY_API_TOKEN=your_access_token_here

# OR local Alby Hub connection (laptop must stay on):
# Alby Hub → Connections → New Connection → copy FULL string (one line)
NWC_URL=nostr+walletconnect://paste_here

# Railway: Variables tab → New Variable → paste entire string, no line breaks
# Must include: ?relay=wss://...&secret=...

PORT=3000

# Custom domain (all payment/office links use this URL)
# PUBLIC_BASE_URL=https://globa-cash.us

# PostgreSQL (Railway: add Postgres plugin, then link DATABASE_URL to this service)
DATABASE_URL=postgresql://user:password@host:5432/railway

# Admin portal login (change these in production!)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-this-password

# Optional: default contact email for new deployments
# CONTACT_EMAIL=payments@yourcompany.com

# Background payment sync interval in ms (default 30000)
# SYNC_INTERVAL_MS=30000

# Optional: JSON fallback folder when DATABASE_URL is not set (local dev)
# DATA_DIR=./data
